{
  "name": "ethereum-backend",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS backend: API, event-listener, indexer, notification",
  "scripts": {
    "build": "nest build api && nest build event-listener && nest build indexer && nest build notification",
    "start:api": "nest start api --watch",
    "start:listener": "nest start event-listener --watch",
    "start:indexer": "nest start indexer --watch",
    "start:notification": "nest start notification --watch",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@prisma/client": "^6.1.0",
    "amqplib": "^0.10.5",
    "ethers": "^6.13.4",
    "ioredis": "^5.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/amqplib": "^0.10.6",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "prisma": "^6.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
